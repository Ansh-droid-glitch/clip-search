{
  "name": "ClipSearch",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Semantic vector search clipboard history manager",
  "author": "Ansh",
  "desktopName": "clipsearch",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:react dev:electron",

    "dev:react": "vite",

    "dev:electron": "cross-env NODE_ENV=development electron .",

    "build": "tsc -b && vite build",

    "lint": "eslint .",

    "preview": "vite preview",

    "transpile:electron": "tsc --project src/electron/tsconfig.json",

    "dist:mac": "npm run transpile:electron && npm run build && electron-builder --mac",

    "dist:win": "npm run transpile:electron && npm run build && electron-builder --win",

    "dist:linux": "npm run transpile:electron && npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.Ansh.ClipSearch",

    "productName": "ClipSearch",

    "artifactName": "${productName}-${version}.${ext}",

    "files": [
      "dist-electron/**/*",
      "dist-react/**/*"
    ],

    "directories": {
      "buildResources": "build",
      "output": "dist"
    },

    "mac": {
      "target": ["dmg"],
      "icon": "dist/dekstopicon.icns"
    },

    "linux": {
      "target": ["AppImage"],
      "category": "Utility",
      "icon": "dist/dekstopicon.png"
    },

    "win": {
      "target": ["nsis"],
      "icon": "build/dekstopicon.ico"
    },

    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "os-utils": "^0.0.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}